@article{lim_analyzing_2024,
	title = {Analyzing the {Effectiveness} of a {System} of {Equation} {Model} in {Comparison} to {Single} {Equation} {Models} for {Predicting} {General} {Price} {Level} in {Cambodia}},
	volume = {14},
	issn = {2146-4138},
	url = {https://econjournals.com/index.php/ijefi/article/view/16311},
	doi = {10.32479/ijefi.16311},
	abstract = {This study aims to conduct a comprehensive scenario analysis to predict the dynamics of price levels in Cambodia. Employing a Vector Autoregression (VAR) model, the study examines the relationships among the inflation rate, foreign exchange rate, and money supply. Rigorous unit root testing and lag order selection ensure the appropriateness and accuracy of the modeling approach. The analysis reveals cyclical patterns and mean-reverting properties among inflation, foreign exchange rates, and money supply growth, emphasizing the need for proactive monetary policy measures by the National Bank of Cambodia. The empirical results indicate that foreign exchange rate fluctuations significantly influence inflation, underscoring the importance of effective foreign exchange rate management for domestic price stability. Additionally, variations in money supply impact inflation and foreign exchange rates, highlighting the significance of prudent monetary management for economic growth and price stability. The study underscores the necessity for policymakers' vigilance in responding to the dynamic interactions among inflation, foreign exchange rates, and money supply to stabilize the economy. The study acknowledges limitations, including the focus on quarterly data and the VAR model's assumptions of linear relationships and stationary data, and proposes future research directions to further enhance the understanding of price level dynamics in Cambodia.},
	number = {5},
	urldate = {2026-06-26},
	journal = {International Journal of Economics and Financial Issues},
	author = {Lim, Siphat and Flores, Edman and Barnett, Casey},
	month = sep,
	year = {2024},
	pages = {156--166},
	file = {Full Text:C\:\\Users\\sddes\\Zotero\\storage\\IKC6SP87\\Lim et al. - 2024 - Analyzing the Effectiveness of a System of Equation Model in Comparison to Single Equation Models fo.pdf:application/pdf},
}

@misc{shalat_beyond_2026,
	address = {Rochester, NY},
	type = {{SSRN} {Scholarly} {Paper}},
	title = {Beyond {Inventory} {Logic}: {Social} {Stress} {Indicators} and {Demand} {Forecasting} in {Consumer} {Supply} {Chains}},
	shorttitle = {Beyond {Inventory} {Logic}},
	url = {https://papers.ssrn.com/abstract=6622158},
	doi = {10.2139/ssrn.6622158},
	abstract = {This paper argues that demand forecasting in consumer supply chains should not be treated as a purely technical exercise. Mainstream logistics models are often built around historical sales patterns, inventory logic and algorithmic optimisation. That orientation is useful, but it can understate how demand is shaped by social conditions such as labour-market insecurity, household stress and income volatility. To bridge logistics and sociology, the paper develops a socio-technical forecasting framework and tests it in a proof-of-concept experiment using 202 quarterly observations of U.S. macroeconomic demand data available through the statsmodels macrodata dataset. Quarterly real consumption growth is used as a proxy for demand faced by consumergoods supply chains, while a household stress index is constructed from unemployment and real disposable-income growth. A baseline ARIMA model is compared with a sociotechnical SARIMAX model that incorporates the stress index. In a 12-quarter out-ofsample test covering 2006 Q4 to 2009 Q3, the socio-technical model reduces RMSE from 0.706 to 0.578 and MAE from 0.569 to 0.458, showing that social stress improves forecast performance during turbulent periods. The contribution of the paper is twofold: conceptually, it reframes forecasting as a social as well as technical problem; empirically, it demonstrates that even a simple social indicator can improve demand forecasts when instability matters most.},
	language = {en},
	urldate = {2026-06-26},
	publisher = {Social Science Research Network},
	author = {Shalat, Abdallah},
	month = apr,
	year = {2026},
	keywords = {logistics, Social Stress, sociology, supply chains},
	file = {Full Text PDF:C\:\\Users\\sddes\\Zotero\\storage\\V3GPQK2D\\Shalat - 2026 - Beyond Inventory Logic Social Stress Indicators and Demand Forecasting in Consumer Supply Chains.pdf:application/pdf},
}

@article{sulistijanti_comparing_2024,
	title = {Comparing {Time} {Series} {Predictions} of {COVID}-19 {Deaths} {Using} {SARIMAX}, {Neural} {Network}, and {XGBoost}},
	volume = {3},
	copyright = {Copyright (c) 2024 Wellie Sulistijanti, Nur Khotimah},
	issn = {2980-4841},
	url = {https://ajesh.ph/index.php/gp/article/view/481},
	doi = {10.46799/ajesh.v3i12.481},
	abstract = {Accurate and timely prediction of the development of the Covid-19 pandemic is critical to enabling adaptive responses and supporting better decision-making in pandemic management. This research aims to evaluate the effectiveness of three prediction models—SARIMAX, Neural Network, and XGBoost—in forecasting Covid-19-related deaths worldwide. Historical data from July 1 to August 15, 2020, was utilized to develop and test these models, with performance assessed using Mean Squared Error (MSE), Root Mean Squared Error (RMSE), and Mean Absolute Error (MAE). The findings reveal that the XGBoost model outperformed the other two, achieving the lowest MAE value of 347.87, demonstrating its superior accuracy for short-term trend forecasting. These results highlight the strengths and limitations of various forecasting methods, offering valuable insights for future research and practical applications in epidemic prediction. The implications of this research underscore the potential of advanced predictive models in enabling faster identification and response to health threats, thus contributing to more effective epidemic control and public health preparedness.},
	language = {en},
	number = {12},
	urldate = {2026-06-26},
	journal = {Asian Journal of Engineering, Social and Health},
	author = {Sulistijanti, Wellie and Khotimah, Nur},
	month = dec,
	year = {2024},
	pages = {2751--2758},
	file = {Full Text PDF:C\:\\Users\\sddes\\Zotero\\storage\\JI8AAP7R\\Sulistijanti and Khotimah - 2024 - Comparing Time Series Predictions of COVID-19 Deaths Using SARIMAX, Neural Network, and XGBoost.pdf:application/pdf},
}
